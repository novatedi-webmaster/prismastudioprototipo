# Supply chain security: reject any package version published less than 2 weeks ago
# NOTE: npm's "before" is a static date, not a rolling window like pnpm's minimumReleaseAge.
# Update this date periodically, or use a CI script to set it dynamically:
#   npm config set before=$(date -d "14 days ago" --iso-8601=seconds)
before=2026-03-17T00:00:00Z
